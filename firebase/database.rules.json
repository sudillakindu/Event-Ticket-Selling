{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "events": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() in ['super-admin', 'organizer']"
    },
    "reservations": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "payments": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "tickets": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "qrTokens": {
      ".read": false,
      ".write": false
    },
    "ticketUsages": {
      ".read": false,
      ".write": false
    },
    "auditLogs": {
      ".read": false,
      ".write": false
    }
  }
}